{
  "mcpServers": {
    "interlink": {
      "type": "stdio",
      "command": "${HOME}/.cargo/bin/interlink-mcp",
      "env": {
        "INTERLINK_KEY": "${HOME}/.config/interlink/alice.key",
        "INTERLINK_PEERS": "${HOME}/.config/interlink/alice-peers.json",
        "INTERLINK_URL": "http://127.0.0.1:9440",
        "INTERLINK_AGENT_DB": "${HOME}/.local/state/interlink/alice-agent.redb"
      }
    }
  }
}
