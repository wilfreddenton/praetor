{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "mcp_tool",
            "server": "interlink",
            "tool": "register_session",
            "input": { "session_id": "${session_id}" }
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/progress-nudge.js\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "npx -y interlink-mcp wait",
            "async": true,
            "asyncRewake": true,
            "timeout": 3600
          }
        ]
      }
    ]
  }
}
