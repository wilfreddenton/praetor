{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "mcp__interlink__fetch_request",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/scripts/pretooluse-guard.sh\""
          }
        ]
      },
      {
        "matcher": "mcp__interlink__add_peer|mcp__interlink__remove_peer|mcp__interlink__accept_pair|mcp__interlink__reject_pair",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/scripts/peer-admin-guard.sh\""
          }
        ]
      }
    ]
  }
}
